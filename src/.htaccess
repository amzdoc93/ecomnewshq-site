# EcomNewsHQ — Apache Configuration
Options -Indexes

# Default index files
DirectoryIndex index.html index.htm

# === ALLOW ACCESS TO STATIC FILES ===
<Files "sitemap.xml">
    Order allow,deny
    Allow from all
    Satisfy any
</Files>

<Files "robots.txt">
    Order allow,deny
    Allow from all
    Satisfy any
</Files>

# === URL REWRITING ===
<IfModule mod_rewrite.c>
    Options +FollowSymLinks
    RewriteEngine On

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # Serve directory index.html for clean URLs
    # /amazon-fba/ → /amazon-fba/index.html (handled by DirectoryIndex)
    
    # If file doesn't exist, try adding .html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.+)$ /$1.html [L]
</IfModule>

# === ERROR PAGES ===
ErrorDocument 404 /index.html
ErrorDocument 403 /index.html

# === PERFORMANCE ===
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>

# === SECURITY ===
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Allow .htaccess itself to be read by Apache
<Files ".htaccess">
    Order allow,deny
    Allow from all
</Files>
